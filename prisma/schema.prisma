// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// --- ENUMS ---

enum UserRole {
  ADMIN
  AGENT
}

enum StatutGeographique {
  RADE
  AU_PORT
  A_QUAI
}

// Updated based on your request
enum EtapeStatus {
  NOT_DONE
  DOING
  DONE
}

// --- MODELS ---

model User {
  id                String             @id @default(uuid())
  nom               String
  email             String             @unique
  password          String
  role              UserRole
  codeAgence        String?
  // Relations
  portSelectionne   Port?              @relation(fields: [portId], references: [id])
  portId            String?
  agence            Agence?            @relation(fields: [agenceId], references: [id])
  agenceId          String?
  statistiques      StatistiquesFlotte[]
}

model Port {
  id                String             @id @default(uuid())
  idPort            String             @unique
  nom               String
  // Relations
  meteo             Meteo?
  bathymetrie       Bathymetrie?
  escales           Escale[]
  users             User[]
}

model Agence {
  id                String             @id @default(uuid())
  codeAgence        String             @unique
  nomEntreprise     String
  // Relations
  users             User[]
  escales           Escale[]
}

model Meteo {
  id                String   @id @default(uuid())
  meteo             Float
  temperature       Float
  vitesseVent       Float
  visibilite        Float
  hauteurHoule      Float
  maree             String
  dateHeure         DateTime
  port              Port     @relation(fields: [portId], references: [id])
  portId            String   @unique
}

model Bathymetrie {
  id                String   @id @default(uuid())
  profondeurMax     Float
  profondeurMin     Float
  tirantEauAutorise Float
  longueurQuai      Float
  postesDisponibles Int
  capacite          Int
  port              Port     @relation(fields: [portId], references: [id])
  portId            String   @unique
}

model Escale {
  id                String             @id @default(uuid())
  numeroEscale      Int                @unique
  idPort            String
  eta               DateTime
  statut            StatutGeographique
  
  // The requested EtapeCycle logic moved inside Escale
  avisArriveeStatus EtapeStatus        @default(NOT_DONE)
  dapStatus         EtapeStatus        @default(NOT_DONE)
  activitesStatus   EtapeStatus        @default(NOT_DONE)
  manifesteStatus   EtapeStatus        @default(NOT_DONE)
  badStatus         EtapeStatus        @default(NOT_DONE)

  // Relations
  port              Port               @relation(fields: [portId], references: [id])
  portId            String
  agence            Agence?            @relation(fields: [agenceId], references: [id])
  agenceId          String?
  navire            Navire             @relation(fields: [navireId], references: [id])
  navireId          String
}

model Navire {
  id             String   @id @default(uuid())
  nom            String
  type           String
  longueur       Float
  pavillon       String
  consignataire  String
  escales        Escale[]
}

model StatistiquesFlotte {
  id                    String @id @default(uuid())
  nbEnRade              Int
  nbAuPort              Int
  nbAQuai               Int
  totalSousGestion      Int
  user                  User   @relation(fields: [userId], references: [id])
  userId                String
}